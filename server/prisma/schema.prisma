// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExerciseType {
  WEIGHTED
  BODYWEIGHT
  CARDIO
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  LEGS
  GLUTES
  CORE
  CARDIO
  FULL_BODY
}

// User table

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  age           Int?
  sex           Sex?
  weight        Float?
  height        Float?
  weeklyGoal    Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  refreshTokens RefreshToken[] // Multiple tokens if multiple devices
  workouts      Workout[]
  exercises     Exercise[]
}

// Refresh token table, used for staying authenticated longer

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Exercise table

model Exercise {
  id               String            @id @default(cuid())
  name             String
  type             ExerciseType
  muscleGroup      MuscleGroup
  userId           String?
  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl         String?
  isPublic         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  workoutExercises WorkoutExercise[]
}

// Workout table

model Workout {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String?
  note             String?
  date             DateTime          @default(now())
  duration         Int?
  restTimer        Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workoutExercises WorkoutExercise[]
}

// Workout exercise table

model WorkoutExercise {
  id            String   @id @default(cuid())
  workoutId     String
  workout       Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId    String
  exercise      Exercise @relation(fields: [exerciseId], references: [id])
  order         Int
  supersetGroup Int?
  note          String?
  createdAt     DateTime @default(now())
  sets          Set[]
}

// Set table

model Set {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  order             Int
  reps              Int?
  weight            Float?
  duration          Int?
  distance          Float?
  createdAt         DateTime        @default(now())
}